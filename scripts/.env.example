# Prisma SASE API Credentials
# Copy this file to one of the following locations:
#   1. .env (in your project directory)
#   2. ~/.sase/.env (global config, shared across all projects)
#
# The auth helper will auto-discover these credentials — no need to export them manually.
# IMPORTANT: Never commit .env files to version control!

PRISMA_CLIENT_ID=your_service_account@your_tsg.iam.panserviceaccount.com
PRISMA_CLIENT_SECRET=your_client_secret_here
PRISMA_TSG_ID=your_tsg_id_here
